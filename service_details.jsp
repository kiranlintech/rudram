                        <div class="form-group" style="display: flex;justify-content: space-evenly;align-items: baseline;">
                            
                           <h3 class="mr-2">Click here to enroll with us</h3> <span class="fa fa-arrow-right" style="font-size: x-large;color: #025497;"></span><button class="theme-btn style-one" type="submit">Enroll Now</button>
