function switchVMTab(id, btn) {
    document.querySelectorAll('.vm-tab-btn').forEach(function(b) {
        b.classList.remove('active');
        b.style.borderBottomColor = '#4b2a1';
        b.style.color = '#4b2a1';
    });
    document.querySelectorAll('.vm-panel').forEach(function(p) {
        p.style.display = 'none';
    });
    btn.classList.add('active');
    btn.style.borderBottomColor = '#4b2a1';
    btn.style.color = '#4b2a1';

    var panel = document.getElementById('vm-panel-' + id);
    panel.style.display = 'block';
    panel.style.animation = 'none';
    panel.offsetHeight; // trigger reflow
    panel.style.animation = 'vmfadein 0.22s ease';

    var word = id.charAt(0).toUpperCase() + id.slice(1);
    document.getElementById('tab-word').textContent = word+"?";
    document.getElementById('tab-word').style.color = '#4b2a1';
}

//Select elements
const modal = document.getElementById("popupModal");
const btn = document.getElementById("openPopupBtn"); // Assuming this is your "Donate Now" button ID
const span = document.getElementsByClassName("close-modal-redesign")[0];

// Define Open Modal function
function openModal() {
  modal.style.display = "block";
  document.body.classList.add('modal-open'); // Optional: Adds class to body to prevent scrolling background
}

// Define Close Modal function
function closeModal() {
  modal.style.display = "none";
  document.body.classList.remove('modal-open');
}

// --- Event Listeners ---

// 1. Check if btn exists first to avoid console errors
if (btn) {
  btn.onclick = function(event) {
    // PREVENT PAGE RELOAD
    if (event.preventDefault) { event.preventDefault(); } 
    event.returnValue = false; // Legacy IE fix
    
    // Show modal
    openModal();
  }
}

// 2. Close when user clicks (X)
if (span) {
  span.onclick = function() {
    closeModal();
  }
}

// 3. Close when user clicks anywhere on the dark overlay (background)
window.onclick = function(event) {
  if (event.target == modal) {
    closeModal();
  }
}
</script>

